@article{han2016IntJHealthGeographics,
  title = {Using Gini Coefficient to Determining Optimal Cluster Reporting Sizes for Spatial Scan Statistics},
  author = {Han, Junhee and Zhu, Li and Kulldorff, Martin and Hostovich, Scott and Stinchcomb, David G. and Tatalovich, Zaria and Lewis, Denise Riedel and Feuer, Eric J.},
